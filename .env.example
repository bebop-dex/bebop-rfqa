# Deployer account (required for all --network deploys except hardhat)
DEPLOYER_PRIVATE_KEY=

# Etherscan API key — required for verify:router / verify:oracle
ETHERSCAN_API_KEY=

# RPC URLs (optional — sensible public defaults are used if unset)
# Recommended: use a private RPC (Alchemy / Infura / QuickNode) for mainnet deploys.
# Public RPCs sometimes enforce a per-tx fee cap (e.g. Polygon public RPCs reject
# txs whose fee exceeds 1 MATIC, which a 4M-gas deployment hits at high gas prices).
MAINNET_RPC_URL=
SEPOLIA_RPC_URL=
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
POLYGON_RPC_URL=
BASE_RPC_URL=

# Optional explicit gas-price (wei) per network. Set this if your RPC enforces a
# fee cap and gas estimation is too high. Example: 50 gwei = 50000000000.
MAINNET_GAS_PRICE=
SEPOLIA_GAS_PRICE=
ARBITRUM_GAS_PRICE=
OPTIMISM_GAS_PRICE=
POLYGON_GAS_PRICE=
BASE_GAS_PRICE=

# Deploy-time constructor arg overrides (optional — otherwise values from config/deploy.ts are used)
PROTOCOL_TREASURY=
ROUTER_SIGNER=
BEBOP_PMM=
PERMIT2=
WRAPPED_NATIVE_TOKEN=
